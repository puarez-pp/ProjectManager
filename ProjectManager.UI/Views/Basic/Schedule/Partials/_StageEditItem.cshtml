@using ProjectManager.Application.Schedules.Commands.CreateSchedule
@model ScheduleStageEditVm
@{
    var index = (string)ViewData["index"];
}

<div class="card mb-3 schedule-stage-edit"
     data-stage-index="@index">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <strong>Etap</strong>
        </div>
        <button type="button"
                class="btn btn-sm btn-outline-danger js-remove-stage">
            <i class="fa fa-trash"></i>
        </button>
    </div>
    <div class="card-body">
        @Html.Hidden($"Stages[{index}].Order", Model.Order)

        <div class="mb-2">
            <label class="form-label">Nazwa</label>
            <input name="Stages[@index].Name"
                   value="@Model.Name"
                   class="form-control" />
        </div>

        <div class="mb-2">
            <label class="form-label">Opis</label>
            <textarea name="Stages[@index].Description"
                      class="form-control">@Model.Description</textarea>
        </div>

        <div class="row mb-2">
            <div class="col">
                <label class="form-label">Planowany start</label>
                <input type="date"
                       name="Stages[@index].PlannedStart"
                       value="@(Model.PlannedStart?.ToString("yyyy-MM-dd"))"
                       class="form-control" />
            </div>
            <div class="col">
                <label class="form-label">Planowany koniec</label>
                <input type="date"
                       name="Stages[@index].PlannedEnd"
                       value="@(Model.PlannedEnd?.ToString("yyyy-MM-dd"))"
                       class="form-control" />
            </div>
        </div>

        <h6>Zadania</h6>
        <div class="schedule-tasks-container"
             data-stage-index="@index">
            @for (int t = 0; t < Model.Tasks.Count; t++)
            {
                ViewData["stageIndex"] = index;
                ViewData["taskIndex"] = t.ToString();
                @Html.PartialAsync("~/Views/Basics/Schedule/Partial/_TaskEditRow.cshtml", Model.Tasks[t], ViewData)
            }
        </div>

        <button type="button"
                class="btn btn-sm btn-outline-primary mt-2 js-add-task"
                data-stage-index="@index">
            <i class="fa fa-plus"></i> Dodaj zadanie
        </button>
    </div>
</div>
