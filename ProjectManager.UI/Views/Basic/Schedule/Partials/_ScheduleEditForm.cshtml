@using ProjectManager.Application.Schedules.Commands.CreateSchedule
@model ScheduleEditVm

<form asp-action="@(Model.Id == 0 ? "Create" : "Edit")"
      method="post"
      id="schedule-edit-form">
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.Id)
    @Html.HiddenFor(m => m.ProjectId)

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Comment" class="form-label"></label>
        <textarea asp-for="Comment" class="form-control"></textarea>
        <span asp-validation-for="Comment" class="text-danger"></span>
    </div>

    <hr />

    <h5>Etapy i zadania</h5>

    <div id="schedule-stages-container"
         data-stage-template-id="stage-template"
         data-task-template-id="task-template">
        @for (int i = 0; i < Model.Stages.Count; i++)
        {
            @Html.PartialAsync("~/Views/Basics/Schedule/Partial/_StageEditItem.cshtml", Model.Stages[i], new ViewDataDictionary(ViewData) { { "index", i } })
        }
    </div>

    <button type="button"
            class="btn btn-outline-primary mt-2 js-add-stage">
        <i class="fa fa-plus"></i> Dodaj etap
    </button>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary">
            Zapisz
        </button>
        <a asp-action="Schedules"
           asp-route-projectId="@Model.ProjectId"
           class="btn btn-secondary">
            Anuluj
        </a>
    </div>
</form>

@* Szablony hidden dla JS *@
<div id="stage-template" class="d-none">
    @Html.PartialAsync("~/Views/Basics/Schedule/Partial/_StageEditItem.cshtml",
    new ProjectManager.Application.Schedules.Commands.CreateSchedule.ScheduleStageEditVm(),
        new ViewDataDictionary(ViewData) { { "index", "__INDEX__" } })
</div>

<div id="task-template" class="d-none">
    @Html.PartialAsync("~/Views/Basics/Schedule/Partial/_TaskEditRow.cshtml",
        new ProjectManager.Application.Schedules.Commands.CreateSchedule.ScheduleTaskEditVm(),
        new ViewDataDictionary(ViewData) { { "stageIndex", "__SINDEX__" }, { "taskIndex", "__TINDEX__" } })
</div>
