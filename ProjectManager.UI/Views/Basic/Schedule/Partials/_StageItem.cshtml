@using ProjectManager.Application.Schedules.Queries.GetSchedule

@model ScheduleStageVm

<li class="list-group-item schedule-stage-item"
    data-stage-id="@Model.Id">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <strong>@Model.Name</strong>
            @if (!string.IsNullOrWhiteSpace(Model.Name))
            {
                <span class="text-muted small"> – @Model.Name</span>
            }
            <div class="small text-muted">
                @Model.PlannedStart?.ToString("yyyy-MM-dd") - @Model.PlannedEnd?.ToString("yyyy-MM-dd")
            </div>
        </div>
    </div>

    @if (Model.Tasks.Any())
    {
        <ul class="list-group list-group-flush mt-2">
        @foreach (var task in Model.Tasks.OrderBy(t => t.Order))
        {
                @Html.PartialAsync("~/Views/Basics/Schedule/Partial/_TaskRow.cshtml", task)
        }
        </ul>
    }
</li>
