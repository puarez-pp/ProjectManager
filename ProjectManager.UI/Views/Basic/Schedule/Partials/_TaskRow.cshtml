@using ProjectManager.Application.Common.Extensions
@using ProjectManager.Application.Schedules.Queries.GetSchedule
@model ScheduleTaskVm

<li class="list-group-item schedule-task-row d-flex justify-content-between align-items-center"
    data-task-id="@Model.Id">
    <div>
        <span class="badge bg-light text-muted me-2">#@Model.Order</span>
        <strong>@Model.Name</strong>
        @if (!string.IsNullOrWhiteSpace(Model.Name))
        {
            <span class="text-muted small"> – @Model.Name</span>
        }
        <div class="small text-muted">
            @Model.PlannedStart?.ToString("yyyy-MM-dd") - @Model.PlannedEnd?.ToString("yyyy-MM-dd")
        </div>
    </div>
    <div class="d-flex align-items-center gap-2">
        <span class="badge bg-@Model.StatusBootstrapClass">@Model.Status.GetDisplayName()</span>
        @if (!string.IsNullOrEmpty(Model.AssignedUser))
        {
            <span class="small">
                <i class="fa fa-user"></i> @Model.AssignedUser
            </span>
        }
        <button type="button"
                class="btn btn-sm btn-outline-success js-task-status-toggle"
                data-task-id="@Model.Id">
            <i class="fa fa-check"></i>
        </button>
    </div>
</li>
