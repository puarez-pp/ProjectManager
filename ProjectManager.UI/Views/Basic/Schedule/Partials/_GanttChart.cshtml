@model CriticalPathResultDto
@using System.Text.Json
@using ProjectManager.Application.Schedules.Dto

@{
    var tasksJson = JsonSerializer.Serialize(Model.Tasks);
}

<div class="mb-3">
    <h4>Wykres Gantta</h4>

    <div class="d-flex gap-3 mb-2">
        <span class="badge bg-danger">Ścieżka krytyczna</span>
        <span class="badge bg-primary">Zadania niekrytyczne</span>
    </div>

    <div id="gantt-container" class="border p-2" style="position: relative; height: 450px; overflow-y: auto;">
    </div>
</div>

@section Styles {
    <style>
        .gantt-row {
            position: relative;
            height: 32px;
            border-bottom: 1px solid #eee;
        }

        .gantt-label {
            position: absolute;
            left: 0;
            top: 6px;
            width: 180px;
            font-size: 0.85rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .gantt-bar {
            position: absolute;
            height: 18px;
            top: 7px;
            border-radius: 4px;
        }

        .gantt-bar-critical {
            background-color: #dc3545;
        }

        .gantt-bar-normal {
            background-color: #0d6efd;
        }

        .gantt-timeline {
            position: sticky;
            top: 0;
            background: #f8f9fa;
            z-index: 2;
            border-bottom: 1px solid #ddd;
        }

        .gantt-timeline-scale {
            position: relative;
            margin-left: 180px;
            height: 24px;
        }

        .gantt-timeline-tick {
            position: absolute;
            top: 0;
            height: 100%;
            border-left: 1px solid #ccc;
            font-size: 0.7rem;
            padding-left: 2px;
        }

    </style>
}

@section Scripts {
    <script>
        (function () {
            const tasks = JSON.parse('@Html.Raw(tasksJson)');

            if (!tasks || tasks.length === 0) {
                document.getElementById('gantt-container').innerHTML = '<p>Brak danych.</p>';
                return;
            }

            const container = document.getElementById('gantt-container');

            // Używamy PlannedStart/PlannedEnd jeśli są dostępne
            const validTasks = tasks.filter(t => t.plannedStart && t.plannedEnd);

            if (validTasks.length === 0) {
                container.innerHTML = '<p>Brak dat planowanych — nie można narysować Gantta.</p>';
                return;
            }

            const minStart = Math.min(...validTasks.map(t => new Date(t.plannedStart).getTime()));
            const maxEnd = Math.max(...validTasks.map(t => new Date(t.plannedEnd).getTime()));

            const totalMs = maxEnd - minStart;
            const pxPerMs = 800 / totalMs;

            // Oś czasu
            const timeline = document.createElement('div');
            timeline.className = 'gantt-timeline';

            const scale = document.createElement('div');
            scale.className = 'gantt-timeline-scale';

            const steps = 10;
            for (let i = 0; i <= steps; i++) {
                const ratio = i / steps;
                const tick = document.createElement('div');
                tick.className = 'gantt-timeline-tick';
                tick.style.left = (ratio * 100) + '%';

                const date = new Date(minStart + totalMs * ratio);
                tick.textContent = date.toLocaleDateString();

                scale.appendChild(tick);
            }

            timeline.appendChild(scale);
            container.appendChild(timeline);

            // Wiersze z zadaniami
            validTasks
                .sort((a, b) => new Date(a.plannedStart) - new Date(b.plannedStart))
                .forEach((t) => {
                    const row = document.createElement('div');
                    row.className = 'gantt-row';

                    const label = document.createElement('div');
                    label.className = 'gantt-label';
                    label.textContent = t.name;

                    const bar = document.createElement('div');
                    bar.className = 'gantt-bar ' + (t.isCritical ? 'gantt-bar-critical' : 'gantt-bar-normal');

                    const start = new Date(t.plannedStart).getTime();
                    const end = new Date(t.plannedEnd).getTime();

                    const left = (start - minStart) * pxPerMs;
                    const width = Math.max((end - start) * pxPerMs, 4);

                    bar.style.left = (180 + left) + 'px';
                    bar.style.width = width + 'px';

                    bar.title = `${t.name}\nStart: ${t.plannedStart}\nKoniec: ${t.plannedEnd}`;

                    row.appendChild(label);
                    row.appendChild(bar);
                    container.appendChild(row);
                });
        })();
    </script>
}
