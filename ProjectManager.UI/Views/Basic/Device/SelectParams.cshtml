@using ProjectManager.Application.Common.Extensions
@using ProjectManager.Application.DeviceHeaders.Queries.GetDeviceHeaders
@using ProjectManager.Application.Devices.Queries.GetDevice
@using ProjectManager.Application.Devices.Queries.GetSelectParams
@using ProjectManager.Domain.Enums
@using System.Globalization
@model DeviceParamNamesDto

@{
    ViewData["Title"] = "Wybór parametrów";
    var locale = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}

@section Styles {
    <partial name="Styles/_DataTablesStyles" />
    <partial name="Scripts/_DateTimeScripts" />
}

<div class="card shadow-sm mb-4 border-0">

    <!-- NAGŁÓWEK KARTY -->
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center mt-3">
        <h4 class="mb-0 d-flex align-items-center">
            <i class="fas fa-folder-open me-2"></i>
            @Model.Name
        </h4>

        <div class="d-flex gap-2">

            <button class="btn btn-outline-light btn-sm"
                    type="button"
                    onclick="location.href='@Url.Action("Device", "Device", new { id = Model.Id })'">
                <i class="fa-solid fa-arrow-left me-1"></i> Powrót
            </button>
        </div>
    </div>

    <!-- TREŚĆ KARTY -->
    <div class="card-body">

        <div class="row">

            <!-- LEWA KOLUMNA -->
            <div class="col-md-6">

                <p class="mb-2">
                    <i class="fas fa-info-circle text-secondary me-2"></i>
                    Typ urządzenia:
                    <span class="badge bg-info text-dark ms-1">
                        @Model.DeviceType.GetDisplayName()
                    </span>
                </p>

                <p class="mb-2">
                    <i class="fas fa-tags text-secondary me-2"></i>
                    Opis urządenia:
                    <b>@Model.Description</b>
                </p>
            </div>
        </div>
        <form asp-action="Params" asp-controller="Device" method="get">

            <input type="hidden" name="id" value="@Model.Id" />

            <div class="row mb-3">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Od:</label>
                    <input type="date" class="form-control" name="start" required />
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold">Do:</label>
                    <input type="date" class="form-control" name="end" required />
                </div>
            </div>
            <div id="headers-container">
                <partial name="_SelectParamsTable" model="Model" />
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-chart-line me-1"></i> Pokaż parametry
                </button>
            </div>

        </form>
    </div>
</div>
<div id="modal-container"></div>

@section Scripts {

    <partial name="Scripts/_DataTablesScripts" />
    <partial name="Scripts/_DateTimeScripts" />

    <script>
       $(document).ready(function () {

               dtParams = $('#params').DataTable({
               paging: false,
               ordering: false,
               info: true,
               responsive: true,
               autoWidth: false,
               lengthChange: true,
               language: {
                   url: `/lib/datatables/lang/${'@locale'}.json`
               },
           });

       });
        
    </script>
}
