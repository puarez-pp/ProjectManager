
@using ProjectManager.Application.Devices.Queries.GetDevice
@model DeviceDto

<table id="headers" class="table table-striped table-bordered align-middle">
    <thead class="table-light">
        <tr>
            <th>Lp</th>
            <th>Nazwa</th>
            <th>Opis</th>
            <th class="text-center" style="width: 180px;">Akcje</th>
        </tr>
    </thead>

    <tbody>
        @{
            int index = 1;
        }
        @foreach (var header in Model.DeviceHeaders)
        {
            <tr>
                <td class="fw-semibold">@index</td>
                <td class="fw-semibold">@header.Name</td>
                <td>@header.Description</td>
                <td class="text-center">
                    @if (!Model.IsConfigured)
                    {
                        <button class="btn btn-sm btn-outline-success open-edit-header-modal"
                                data-position="@header.Id">
                            <i class="fas fa-pen-to-square"></i> Edytuj
                        </button>
                        <button class="btn btn-sm btn-outline-danger open-delete-header-modal"
                                data-position="@header.Id">
                            <i class="fas fa-trash-can me-1"></i> Usuń
                        </button>
                    } 
                </td>
            </tr>
            index++;
        }
    </tbody>
</table>
