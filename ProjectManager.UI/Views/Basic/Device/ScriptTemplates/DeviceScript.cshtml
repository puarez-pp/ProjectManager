@using ProjectManager.Application.Devices.Commands.AddScript
@model DeviceSriptVm
@{
    Layout = null;
}
let jwtToken = null;

// --- PREKOMPILACJA TAGÓW ---

const headers = [
@foreach (var h in Model.Headers.OrderBy(h => h.Order))
{
    @:{ name: "@h.Name" },
}
];

// Prekompilowane funkcje odczytu wartości
const readers = [
@foreach (var h in Model.Headers.Where(h => h.Used).OrderBy(h => h.Order))
{
    @:() => Globals.Tags.GetTag("@h.Name").Read(),
}
];

// Prealokowana tablica DTO
const dtoArray = new Array(headers.length);
for (let i = 0; i < headers.length; i++) {
    dtoArray[i] = {
        timeStamp: "",
        name: headers[i].name,
        value: 0
    };
}

// --- AUTORYZACJA ---

function authenticate() {
    var req = HMIRuntime.HttpRequest("@Model.AuthUrl");

    req.Method = "POST";
    req.SetHeader("Content-Type", "application/json");

    var body = JSON.stringify({
        userName: "@Model.Username",
        password: "@Html.Raw(Model.Password)"
    });

    req.Send(body);

    var resp = req.GetResponseString();
    if (!resp) {
        HMIRuntime.Trace("Auth error: empty response");
        return;
    }

    try {
        var data = JSON.parse(resp);
        jwtToken = data.token;
    } catch (e) {
        HMIRuntime.Trace("Auth parse error: " + e);
    }
}

// --- WYSYŁANIE PARAMETRÓW ---

function sendParams() {

    if (!jwtToken) {
        authenticate();
        if (!jwtToken) {
            HMIRuntime.Trace("Auth failed, skipping send");
            return;
        }
    }

    var now = new Date().toISOString();

    // Wypełnianie DTO
    for (let i = 0; i < dtoArray.length; i++) {
        dtoArray[i].timeStamp = now;
        dtoArray[i].value = readers[i]();
    }

    var payload = {
        deviceId: @Model.DeviceId,
        deviceParams: dtoArray
    };

    var req = HMIRuntime.HttpRequest("@Model.ApiUrl");
    req.Method = "POST";
    req.SetHeader("Content-Type", "application/json");
    req.SetHeader("Authorization", "Bearer " + jwtToken);

    var json = JSON.stringify(payload);

    req.Send(json);

    var resp = req.GetResponseString();
    if (!resp) {
        HMIRuntime.Trace("Send error: empty response");
    }
}

// --- INTERWAŁ ---

HMIRuntime.SetInterval(sendParams, @Model.IntervalMs);
