@using ProjectManager.Application.Common.Extensions
@using ProjectManager.Application.Devices.Queries.GetEditDevice
@using ProjectManager.Domain.Enums
@model EditDeviceVm

@section Styles {
    <partial name="Styles/_EditorStyles" />
    <partial name="Styles/_SelectStyles" />
}

<div class="container mt-4">

    <!-- Informacje o instalacji -->
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Informacje o instalacji</h5>
        </div>
        <div class="card-body">

            <dl class="row mb-4">
                <dt class="col-sm-3">Nazwa</dt>
                <dd class="col-sm-9">@Model.Plant.Name</dd>

                <dt class="col-sm-3">Lokalizacja</dt>
                <dd class="col-sm-9">@Model.Plant.Location</dd>

                <dt class="col-sm-3">Utworzono</dt>
                <dd class="col-sm-9">@Model.Plant.CreatedAt.ToString("yyyy-MM-dd")</dd>
            </dl>

            <!-- Lista urządzeń -->
            <h6 class="fw-bold mb-3">
                <i class="fa-solid fa-network-wired me-1"></i> Urządzenia istniejące
            </h6>

            @if (Model.Plant.Devices.Any())
            {
                <table class="table table-striped table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>Nazwa</th>
                            <th>Typ</th>
                            <th>Utworzono</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.Plant.Devices)
                        {
                            <tr>
                                <td>@d.Name</td>
                                <td>@d.DeviceType.GetDisplayName()</td>
                                <td>@d.CreatedAt.ToString("yyyy-MM-dd")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted fst-italic">Brak urządzeń w wybranej instalacji.</p>
            }
        </div>
    </div>
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Edycja urządzenia</h5>
        </div>

        @using (Html.BeginForm("EditDevice", "Device"))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(x => x.Device.Id)
            @Html.HiddenFor(x => x.Plant.UserId)

            <div class="card-body">

                <div class="form-group">
                    @Html.LabelFor(x => x.Device.Name)
                    @Html.TextBoxFor(x => x.Device.Name, new { @class = "form-control", placeholder = "Wprowadź nazwę urządzenia" })
                    @Html.ValidationMessageFor(x => x.Device.Name)
                </div>

                <div class="form-group">
                    @Html.LabelFor(x => x.Device.Description)
                    @Html.TextBoxFor(x => x.Device.Description, new { @class = "form-control", placeholder = "Wprowadź opis urządzenia" })
                    @Html.ValidationMessageFor(x => x.Device.Description)
                </div>

                <div class="form-group">
                    @Html.LabelFor(x => x.Device.DeviceType)
                    <div class="select2-blue">
                        @Html.DropDownList("Device.DeviceType", Html.GetEnumSelectList<DeviceType>(), null, htmlAttributes: new { @class = "form-control select2-DeviceType", style = "width: 100%;" })
                        @Html.ValidationMessageFor(x => x.Device.DeviceType)
                    </div>
                </div>
            </div>

            <div class="card-footer">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="fas fa-solid fa-circle-check"></i>Zapisz
                </button>
            </div>

        }
    </div>
</div>

@section Scripts {
    <partial name="Scripts/_ValidationScriptsPartial" />
    <partial name="Scripts/_EditorScripts" />
    <partial name="Scripts/_SelectScripts" />

    <script>
        $(document).ready(function() {
            $('.select2-DeviceType').select2({
                theme: 'bootstrap-5'
            });
        });
    </script>
}
