@using ProjectManager.Application.DeviceHeaders.Commands.EditDeviceHeader

@model EditDeviceHeaderCommand

<div class="modal" id="modal-edit-header" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="edit-header-form">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="DeviceId" />
                <div class="modal-header">
                    <h4 class="modal-title">Edycja parametru</h4>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body"> 
                    <div class="form-group">
                        @Html.LabelFor(x => x.Name)
                        @Html.TextBoxFor(x => x.Name, new { @class = "form-control", placeholder = "Wprowadź nazwę" })
                        @Html.ValidationMessageFor(x => x.Name)
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(x => x.Description)
                        @Html.TextBoxFor(x => x.Description, new { @class = "form-control", placeholder = "Wprowadź opis" })
                        @Html.ValidationMessageFor(x => x.Description)
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anuluj</button>
                    <button id="modal-edit-header-btn" type="submit" class="btn btn-primary">Zapisz</button>
                </div>
            </form>
        </div>
    </div>
</div>

