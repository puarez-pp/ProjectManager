@using ProjectManager.Application.Dictionaries
@using ProjectManager.Application.Settlements.Queries.GetFinancialControl
@model FinancialControlVm

@{
    var canDelete = User.IsInRole(RolesDict.Administrator);
    var canEdit = User.IsInRole(RolesDict.Administrator) || User.IsInRole(RolesDict.Kierownik);
}

<div class="row">

    <!-- SUMY FAKTUR -->
    <div class="col-12 mb-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-calculator me-2"></i> Zestawienie sum netto
                </h5>
            </div>

            <div class="card-body p-0">
                <div id="summaryContainer">
                    <partial name="_SummaryTablePartial" model="Model" />
                </div>
            </div>
        </div>
    </div>

    <!-- LISTA FAKTUR -->
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-file-invoice me-2"></i> Lista faktur
                </h5>

                <button class="btn btn-primary"
                        onclick="location.href='@Url.Action("AddInvoice", "Settlement", new { id = Model.Project.Id })'">
                    <i class="fas fa-plus me-2"></i> Dodaj fakturę
                </button>
            </div>

            <div class="card-body p-0">
                <table id="invoicesTable" class="table table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th>Numer</th>
                            <th>Data</th>
                            <th>Dostawca</th>
                            <th>Zakres</th>
                            <th>Kwota netto [PLN]</th>
                            <th>Kwota netto [EUR]</th>
                            <th>Kurs EUR</th>
                            <th>Nr zamówienia</th>
                            <th class="text-end">Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in Model.Invoices)
                        {
                            <tr data-invoice-id = "@inv.Id">
                                <td>@inv.Number</td>
                                <td>@inv.IssueDate.ToString("yyyy-MM-dd")</td>
                                <td>@inv.Vendor</td>
                                <td>@inv.ScopeDescription</td>
                                <td>@inv.NetAmount.ToString("N2")</td>
                                <td>@inv.EuroNetAmount.ToString("N2")</td>
                                <td>@inv.EuroRate.ToString("N4")</td>
                                <td>@inv.OrderNumber</td>

                                <td class="text-end">

                                    @if (canEdit)
                                    {
                                        <button class="btn btn-sm btn-outline-success me-1"
                                                onclick="location.href='@Url.Action("EditInvoice", "Settlement", new { id = inv.Id})'">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                    }

                                    @if (canDelete)
                                    {
                                        <button class="btn btn-sm btn-outline-danger open-delete-invoice-confirm"
                                                data-invoice-id="@inv.Id">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    }

                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>

</div>

<script>
    
</script>
