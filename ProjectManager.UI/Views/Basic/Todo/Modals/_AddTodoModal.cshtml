
<div class="modal fade" id="addEditTodoModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Zadanie</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="TodoId" />

                <div class="mb-3">
                    <label class="form-label">Tytuł</label>
                    <input type="text" id="TodoTitle" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Opis</label>
                    <textarea id="TodoBody" class="form-control"></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Przypisane do</label>
                    <select id="TodoUserToId" class="form-select">
                        <option value="">-- wybierz użytkownika --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Termin wykonania</label>
                    <input type="datetime-local" id="TodoDueDate" class="form-control" />
                </div>

                <div class="form-check">
                    <input type="checkbox" id="TodoIsCompleted" class="form-check-input" />
                    <label class="form-check-label">Zakończone</label>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Anuluj</button>
                <button class="btn btn-primary" id="btnSaveTodo">Zapisz</button>
            </div>
        </div>
    </div>
</div>
