@using ProjectManager.Application.Todos.Queries.GetProjectTodos
@model ProjectTodosVm

@foreach (var t in Model.Todos)
{
    <div class="card mb-3 shadow-sm todo-item" data-id="@t.Id">
        <div class="card-body d-flex justify-content-between align-items-start">

            <div>
                <h5 class="card-title @(t.IsCompleted ? "text-decoration-line-through" : "")">
                    @t.Title
                </h5>

                <p class="card-text text-muted small">
                    Utworzone: @t.CreatedAt.ToString("yyyy-MM-dd") przez @t.UserFrom.FullName
                    @if (t.UserTo != null)
                    {
                        <span>• Przypisane do: @t.UserTo.FullName</span>
                    }
                </p>

                <p>@t.Body</p>

                <div class="mt-2">
                    <span class="badge @(t.IsCompleted ? "bg-success" : "bg-warning text-dark")">
                        @(t.IsCompleted ? "Zakończone" : "W toku")
                    </span>

                    <span class="badge bg-secondary">
                        Komentarze: @t.PostsNumber
                    </span>
                </div>
            </div>

            <div class="ms-3">
                <button class="btn btn-sm btn-primary btnEditTodo" data-id="@t.Id">
                    <i class="fas fa-edit"></i>
                </button>

                <button class="btn btn-sm btn-secondary btnAddPost" data-id="@t.Id">
                    <i class="fas fa-comment"></i>
                </button>

                <button class="btn btn-sm btn-danger btnDeleteTodo" data-id="@t.Id">
                    <i class="fas fa-trash"></i>
                </button>
            </div>
        </div>
    </div>
}
