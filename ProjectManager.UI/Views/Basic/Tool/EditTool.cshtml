
@using System.Globalization
@using ProjectManager.Application.Todos.Queries.GetEditTodo

@model EditTodoVm
@{
    ViewData["Title"] = "Edycja zadania";
    var locale = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}

@section Styles {
<partial name="Styles/_SelectStyles" />
<partial name="Styles/_DateTimeStyles" />
}

<div class="card-header bg-primary text-white d-flex justify-content-between align-items-center mt-3 mb-3">
    <h4 class="mb-0 d-flex align-items-center">
        <a class="edit-link text-white" href="/Project/Project?id=@Model.Project.Id">
            <i class="fas fa-folder-open me-2"></i>
            @Model.Project.Name
        </a>
    </h4>
</div>

<div class="card card-primary card-border-top">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.Todo.Id)
        @Html.HiddenFor(x => x.Todo.ProjectId)
        @Html.HiddenFor(x => x.Todo.IsCompleted)
        @Html.HiddenFor(x => x.Project.Id)
        @Html.HiddenFor(x => x.UserTodos)
        @for (int i = 0; i < Model.AvaiableUsers.Count(); i++)
        {
            @Html.HiddenFor(x => x.AvaiableUsers[i].Id)
            @Html.HiddenFor(x => x.AvaiableUsers[i].FullName)
        }
        <div class="card-body row">
            <div class="form-group">
                @Html.LabelFor(x => x.Todo.Title)
                @Html.TextBoxFor(x => x.Todo.Title, new { @class = "form-control", placeholder="Wprowadź tytuł"})
                @Html.ValidationMessageFor(x => x.Todo.Title)
            </div>

            <div class="form-group col-md-6">
                @Html.LabelFor(x => x.Todo.UserToId)
                <div class="select2-blue">
                    @Html.DropDownList("Todo.UserToId", @Model.AvaiableUsers.Select(x => new SelectListItem(x.FullName, x.Id)), null, htmlAttributes: new { @class = "form-control select2-UserId", style = "width: 100%;" })
                    @Html.ValidationMessageFor(x => x.Todo.UserToId)
                </div>
            </div>

            <div class="form-group col-md-6">
                @Html.LabelFor(x => x.Todo.CompletionDate)
                <div class="input-group date" id="dtpDateOfCompletion" data-target-input="nearest">
                    <input asp-for="Todo.CompletionDate" type="text" class="form-control datetimepicker-input" data-target="#dtpDateOfCompletion" />
                    <div class="input-group-append" data-target="#dtpDateOfCompletion" data-toggle="datetimepicker">
                        <div class="input-group-text calendar"><i class="fa fa-calendar"></i></div>
                    </div>
                </div>
                @Html.ValidationMessageFor(x => x.Todo.CompletionDate)
            </div>

            <div class="form-group">
                @Html.LabelFor(x => x.Todo.Body)
                @Html.TextAreaFor(x => x.Todo.Body, new { @class = "form-control", placeholder = "Wprowadź opis" })
                @Html.ValidationMessageFor(x => x.Todo.Body)
            </div>
        </div>

        <div class="card-footer">
             <button type="submit" class="btn btn-primary btn-sm">
                <i class="fas fa-solid fa-circle-check"></i>Zapisz
            </button>
        </div>
    }
</div>

@section Scripts {
    <partial name="Scripts/_ValidationScriptsPartial" />
    <partial name="Scripts/_SelectScripts" />
    <partial name="Scripts/_DateTimeScripts" />

    <script>
        $(document).ready(function() {

            $('#dtpDateOfCompletion').datetimepicker({
            format: 'L',
            locale: '@locale'
            });

            $('.select2-UserId').select2({
                theme: 'bootstrap-5'
            });
        });

    </script>
}