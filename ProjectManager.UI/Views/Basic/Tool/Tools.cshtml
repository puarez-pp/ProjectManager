@using System.Globalization
@using ProjectManager.Application.Dictionaries
@using ProjectManager.Application.Tools.Queries.GetTools
@model List<ToolDto>

@{
    ViewData["Title"] = "Lista analizatorów i mierników";
}

<!-- Modale -->
<partial name="Modals/_RentToolModal" />
<partial name="Modals/_DeleteToolModal" />

<div class="card-header bg-primary text-white d-flex justify-content-between align-items-center mt-3">
    <h4 class="mb-0 d-flex align-items-center edit-link">
            <i class="fa-solid fa-gauge" style="margin-right:5px"></i>
            Mierniki i analizatory
    </h4>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-light"
                type="button"
                onclick="location.href='@Url.Action("Dashboard", "User")'">
            <i class="fa-solid fa-id-card"></i> Mój panel
        </button>

        <button class="btn btn-outline-light" id="btnAddTool"
                type="button"
                onclick="location.href='@Url.Action("AddTool", "Tool")'">
            <i class="fas fa-plus"></i> Dodaj miernik
        </button>
    </div>
</div>

<div id="toolsContainer">
    <partial name="Partials/_ToolsList"
             model="Model"/>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            renumberToolsTable();
        });

    </script>
    <script src="~/js/tool.js"></script>
}
